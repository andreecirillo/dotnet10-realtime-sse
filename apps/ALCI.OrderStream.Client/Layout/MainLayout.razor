@inherits LayoutComponentBase

<div class="min-h-screen bg-slate-50 font-sans text-slate-900">    
    <main class="flex min-h-screen flex-col items-center justify-start px-4 pt-20 pb-24">

        <div class="w-full flex justify-center">
            @Body
        </div>

        <footer class="mt-16 w-full max-w-[650px] border-t border-slate-200 pt-8">
            <div class="flex flex-col items-center text-center gap-1">
                <div class="text-xl font-black tracking-[0.3em] text-slate-900 uppercase leading-none">
                    ALCI
                </div>
                <p class="text-[10px] font-bold tracking-[0.15em] text-slate-400 uppercase leading-relaxed">
                    Artificial Large Collision Intelligence
                </p>
                <div class="mt-2 flex w-full justify-center">
                    <span class="text-[9px] font-medium tracking-[0.3em] text-slate-300 uppercase">© 2026</span>
                </div>
            </div>
        </footer>
    </main>
</div>