@page "/404"
@page "/not-found"

<PageTitle>ALCI - Not Found</PageTitle>

<div class="w-full max-w-[500px] rounded-3xl border-2 border-slate-900 bg-white p-12 shadow-2xl animate-in zoom-in duration-300">

    <header class="mb-8 flex items-center gap-4 border-b border-slate-100 pb-6 text-left">
        <img src="icon-192.png" alt="Logo" class="h-10 w-10 grayscale opacity-50" />
        <div>
            <h1 class="text-2xl font-black text-transparent bg-clip-text bg-linear-to-r from-slate-400 to-slate-600 uppercase">
                Not Found
            </h1>
        </div>
    </header>

    <div class="text-center">
        <h2 class="mb-4 text-3xl font-extrabold text-slate-900">Lost in Transit</h2>
        <p class="mb-8 text-slate-500 font-medium">
            The order or page you are looking for has been diverted or does not exist.
        </p>

        <div class="mb-8 text-6xl">📦❓</div>

        <a href="/" class="inline-block rounded-xl bg-slate-900 px-8 py-3 font-bold text-white transition-all hover:scale-105 active:scale-95">
            ← Return to Home
        </a>

        <div class="mt-10 flex flex-col items-center gap-2 border-t border-slate-100 pt-6">
            <div class="text-[10px] font-black tracking-[0.2em] text-slate-300 uppercase">
                System Status: <span class="text-green-500">Operational</span>
            </div>
        </div>
    </div>
</div>